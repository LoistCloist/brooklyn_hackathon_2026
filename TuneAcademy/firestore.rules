rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function inSortedChat(chatId) {
      let u = request.auth.uid;
      return chatId.matches('^' + u + '_.+') || chatId.matches('.+_' + u + '$');
    }

    function reelLikeOnly() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likedBy', 'likesCount']);
    }

    function reelCommentCountOnly() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['commentsCount']);
    }

    match /users/{userId} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null && request.auth.uid == userId;
    }

    match /instructors/{instructorId} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null && request.auth.uid == instructorId;

      match /receivedReviews/{reviewId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null
          && request.resource.data.learnerId == request.auth.uid
          && request.resource.data.stars is int
          && request.resource.data.stars >= 1
          && request.resource.data.stars <= 5;
        allow update, delete: if false;
      }
    }

    match /reports/{reportId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    match /reels/{reelId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.uploaderId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.uploaderId == request.auth.uid;
      allow update: if request.auth != null && (
        resource.data.uploaderId == request.auth.uid
        || reelLikeOnly()
        || reelCommentCountOnly()
      );

      match /comments/{commentId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null
          && request.resource.data.authorId == request.auth.uid;
        allow update, delete: if false;
      }
    }

    match /invitations/{invitationId} {
      allow read: if request.auth != null
        && (('instructorId' in resource.data && resource.data.instructorId == request.auth.uid)
            || ('learnerId' in resource.data && resource.data.learnerId == request.auth.uid));
      /* Instructor recruits from MusiReels; learner may start a directory or peer DM (see useMessaging). */
      allow create: if request.auth != null
        && 'instructorId' in request.resource.data
        && 'learnerId' in request.resource.data
        && (
          request.resource.data.instructorId == request.auth.uid
          || request.resource.data.learnerId == request.auth.uid
        );
      allow update, delete: if false;
    }

    match /messages/{chatId} {
      allow read: if request.auth != null && inSortedChat(chatId);
      allow write: if request.auth != null && inSortedChat(chatId);
    }

    match /messages/{chatId}/messages/{messageId} {
      allow read: if request.auth != null && inSortedChat(chatId);
      allow create: if request.auth != null
        && inSortedChat(chatId)
        && request.resource.data.senderId == request.auth.uid;
      allow update, delete: if false;
    }

    match /tutoringRequests/{requestId} {
      allow read: if request.auth != null
        && (resource.data.learnerId == request.auth.uid
            || resource.data.instructorId == request.auth.uid);
      allow create: if request.auth != null
        && request.resource.data.learnerId == request.auth.uid
        && request.resource.data.instructorId is string
        && request.resource.data.status == 'pending'
        && request.resource.data.weeks is int
        && request.resource.data.weeks >= 1
        && request.resource.data.weeks <= 52
        && request.resource.data.weeklySlots is list
        && request.resource.data.weeklySlots.size() > 0
        && request.resource.data.message is string
        && request.resource.data.message.size() <= 2000;
      allow update: if request.auth != null
        && resource.data.instructorId == request.auth.uid
        && resource.data.status == 'pending'
        && request.resource.data.status in ['accepted', 'declined']
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']);
      allow delete: if false;
    }

    match /tutoringEngagements/{engagementId} {
      allow read: if request.auth != null
        && (resource.data.learnerId == request.auth.uid
            || resource.data.instructorId == request.auth.uid);
      allow create: if request.auth != null
        && request.resource.data.instructorId == request.auth.uid
        && request.resource.data.learnerId is string
        && request.resource.data.requestId is string
        && request.resource.data.weeks is int
        && request.resource.data.weeklySlots is list
        && request.resource.data.meetings is list;
      allow update, delete: if false;
    }
  }
}
