rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function inSortedChat(chatId) {
      let u = request.auth.uid;
      return chatId.matches('^' + u + '_.+') || chatId.matches('.+_' + u + '$');
    }

    function reelLikeOnly() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likedBy', 'likesCount']);
    }

    function reelCommentCountOnly() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['commentsCount']);
    }

    /** Firestore sends whole numbers as `int` in rules; `is number` alone can reject valid writes. */
    function isNumeric(v) {
      return v is int || v is float;
    }

    /**
     * Session reviews: block only verified instructors. Missing `role`, null, or `learner` all pass.
     * (Using `== 'learner'` alone fails when `role` is null or the field is absent in older docs.)
     */
    function authUserMaySubmitSessionReview() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'learner')
            != 'instructor';
    }

    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null && request.auth.uid == userId;
      /**
       * Own profile: full control.
       * Tutoring: when a session completes, the instructor’s client may run the same transaction
       * as the learner’s to increment `learningBudgetSpentUsd` on the student’s user doc (see
       * `recordMeetLinkOpened`). Only that field, only upward, and only if the caller has an
       * `instructors/{uid}` profile (verified instructor account).
       */
      allow update: if request.auth != null && request.auth.uid == userId
        || (
          request.auth != null
          && exists(/databases/$(database)/documents/instructors/$(request.auth.uid))
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['learningBudgetSpentUsd'])
          && request.resource.data.learningBudgetSpentUsd is number
          && (!('learningBudgetSpentUsd' in resource.data)
              || request.resource.data.learningBudgetSpentUsd >= resource.data.learningBudgetSpentUsd)
        );
    }

    match /instructors/{instructorId} {
      /** Prior aggregate count for learner review txn; non-numeric stored values must not crash rules. */
      function instructorPriorReviewCount() {
        return resource.data.keys().hasAll(['reviewCount']) && isNumeric(resource.data.reviewCount)
          ? int(floor(resource.data.reviewCount))
          : 0;
      }

      allow read, create, update, delete: if request.auth != null;

      match /receivedReviews/{reviewId} {
        allow read, create, update, delete: if request.auth != null;
      }
    }

    match /reports/{reportId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if false;
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    match /reels/{reelId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.uploaderId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.uploaderId == request.auth.uid;
      allow update: if request.auth != null && (
        resource.data.uploaderId == request.auth.uid
        || reelLikeOnly()
        || reelCommentCountOnly()
      );

      match /comments/{commentId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null
          && request.resource.data.authorId == request.auth.uid;
        allow update, delete: if false;
      }
    }

    match /invitations/{invitationId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && 'instructorId' in request.resource.data
        && 'learnerId' in request.resource.data;
      allow update: if request.auth != null
        && (
          resource.data.instructorId == request.auth.uid
          || resource.data.learnerId == request.auth.uid
          || request.resource.data.instructorId == request.auth.uid
          || request.resource.data.learnerId == request.auth.uid
        );
      allow delete: if request.auth != null
        && (
          resource.data.instructorId == request.auth.uid
          || resource.data.learnerId == request.auth.uid
        );
    }

    match /messages/{chatId} {
      allow read: if request.auth != null && inSortedChat(chatId);
      allow write: if request.auth != null && inSortedChat(chatId);
    }

    match /messages/{chatId}/messages/{messageId} {
      allow read: if request.auth != null && inSortedChat(chatId);
      allow create: if request.auth != null
        && inSortedChat(chatId)
        && request.resource.data.senderId == request.auth.uid;
      allow update, delete: if false;
    }

    match /tutoringRequests/{requestId} {
      allow read, create, update, delete: if request.auth != null;
    }

    match /guitarset_tracks/{trackId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /lakh_tracks/{trackId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /tutoringEngagements/{engagementId} {
      allow read, create, update, delete: if request.auth != null;

      match /meetSessions/{sessionId} {
        allow read, create, update, delete: if request.auth != null;
      }
    }
  }
}
